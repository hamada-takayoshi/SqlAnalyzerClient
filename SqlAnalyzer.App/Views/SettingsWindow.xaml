<Window x:Class="SqlAnalyzer.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="720"
        Height="500"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <TabControl>
            <TabItem Header="Formatting">
                <StackPanel Margin="12">
                    <TextBlock Text="Indentation width" />
                    <TextBox Margin="0,4,0,10"
                             Width="120"
                             Text="4" />
                    <CheckBox Content="Uppercase keywords"
                              IsChecked="True" />
                </StackPanel>
            </TabItem>
            <TabItem Header="Logical Name Rules">
                <StackPanel Margin="12">
                    <CheckBox Content="Enable block comment pattern"
                              IsChecked="True" />
                    <CheckBox Margin="0,8,0,0"
                              Content="Enable line comment pattern"
                              IsChecked="True" />
                    <CheckBox Margin="0,8,0,0"
                              Content="Enable whitespace tolerance"
                              IsChecked="True" />
                </StackPanel>
            </TabItem>
            <TabItem Header="Output">
                <StackPanel Margin="12">
                    <TextBlock Text="Default output directory" />
                    <TextBox Margin="0,4,0,10"
                             Text="." />
                    <TextBlock Text="Default filename pattern" />
                    <TextBox Margin="0,4,0,10"
                             Text="SqlAnalysis_{yyyyMMdd_HHmmss}" />
                    <TextBlock Text="Encoding" />
                    <TextBox Margin="0,4,0,10"
                             Text="UTF-8" />
                    <TextBlock Text="Default diagram format" />
                    <ComboBox Margin="0,4,0,0"
                              Width="160"
                              SelectedIndex="0">
                        <ComboBoxItem Content="PNG" />
                        <ComboBoxItem Content="Markdown" />
                    </ComboBox>
                </StackPanel>
            </TabItem>
            <TabItem Header="Runtime">
                <StackPanel Margin="12">
                    <TextBlock Text="Analysis timeout (seconds)" />
                    <TextBox Margin="0,4,0,10"
                             Width="120"
                             Text="30" />
                    <CheckBox Content="Best-effort mode"
                              IsChecked="True" />
                    <TextBlock Margin="0,10,0,0"
                               Text="History size" />
                    <TextBox Margin="0,4,0,0"
                             Width="120"
                             Text="20" />
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
